{
	"name": "auto-kanban",
	"private": true,
	"workspaces": [
		"server",
		"client",
		"e2e"
	],
	"scripts": {
		"prepare": "git config --local core.hooksPath .githooks 2>/dev/null || true",
		"setup:hooks": "git config --local core.hooksPath .githooks",
		"start:dev": "bun run --filter '*' --parallel start:dev",
		"start:prod": "bun run --filter '*' --parallel start:prod",
		"build": "bun run --filter '*' build",
		"check": "bun run --parallel 'check:*' && bun run --filter '@auto-kanban/server' check:schema-upgrade",
		"check:lint": "bun run --filter '*' check:lint",
		"check:test": "bun run --filter '*' --sequential check:test",
		"check:type": "bun run --filter '*' check:type",
		"check:arch": "bun run --filter '*' check:arch",
		"check:specre": "if command -v specre >/dev/null 2>&1; then scripts/specre-quiet.sh health-check --json; else echo '(specre CLI not installed; install with `cargo install specre` to enable spec drift detection)'; fi",
		"fix:lint": "bun run --filter '*' fix:lint",
		"specre:index": "scripts/specre-quiet.sh index",
		"specre:status": "scripts/specre-quiet.sh status",
		"watch": "bun run --parallel 'watch:*'",
		"watch:arch": "bun run --filter '*' --parallel watch:arch",
		"watch:lint": "bun run --filter '*' --parallel watch:lint",
		"watch:test": "bun run --filter '*' --parallel watch:test",
		"watch:type": "bun run --filter '*' --parallel watch:type"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"onchange": "^7.1.0",
		"typescript": "^6.0.2"
	}
}
