{
	"name": "@auto-kanban/server",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV=development bun run --watch src/index.ts",
		"build": "bun build src/index.ts --compile --outfile dist/auto-kanban",
		"start": "bun run src/index.ts",
		"test": "bun test src/",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"arch:check": "depcruise src --config .dependency-cruiser.cjs --output-type err"
	},
	"dependencies": {
		"@hono/trpc-server": "^0.3.2",
		"@modelcontextprotocol/sdk": "^1.12.1",
		"@trpc/server": "11.10.0",
		"hono": "^4.4.0",
		"sqlite-auto-migrator": "^1.0.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"dependency-cruiser": "^17.3.8",
		"typescript": "^5.9.3"
	}
}
