{
	"name": "@auto-kanban/server",
	"version": "0.1.1",
	"private": true,
	"type": "module",
	"scripts": {
		"start:dev": "NODE_ENV=development bun run --watch src/index.ts",
		"start:prod": "bun run src/index.ts",
		"build": "bun build src/index.ts --compile --outfile dist/auto-kanban",
		"check:lint": "biome check .",
		"check:test": "./scripts/run-test.sh src/",
		"check:type": "tsc --noEmit",
		"check:arch": "depcruise src --config .dependency-cruiser.cjs --output-type err",
		"check:schema-upgrade": "bun run scripts/check-schema-upgrade.ts",
		"fix:lint": "biome check --write .",
		"watch:arch": "onchange 'src/**' 'schema/**' --initial -- bun run check:arch",
		"watch:lint": "onchange 'src/**' 'schema/**' --initial -- bun run check:lint",
		"watch:test": "./scripts/run-test.sh --watch src/",
		"watch:type": "tsc --noEmit --watch",
		"postinstall": "node scripts/hydrate-pg-symlinks.mjs"
	},
	"dependencies": {
		"@hono/trpc-server": "^0.3.2",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@trpc/server": "11.10.0",
		"embedded-postgres": "^18.3.0-beta.16",
		"hono": "^4.12.14",
		"jsonc-parser": "^3.3.1",
		"pg": "^8.20.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/pg": "^8.20.0",
		"dependency-cruiser": "^17.3.8",
		"typescript": "^5.9.3"
	}
}
