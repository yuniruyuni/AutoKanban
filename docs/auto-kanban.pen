                      "fontSize": 12,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "LdDyq",
                      "name": "fsTaskDesc",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Terminal output for Claude Code sessions. Shows real-time logs and allows interaction with the AI agent.\n\nThis component should:\n- Display terminal output in a scrollable container\n- Support ANSI color codes\n- Allow user input when agent requests\n- Show execution status and controls",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "frame",
