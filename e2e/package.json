{
	"name": "@auto-kanban/e2e",
	"private": true,
	"type": "module",
	"scripts": {
		"check:lint": "biome check .",
		"check:test": "bun test; EXIT=$?; ./scripts/stop-test-pg.sh; exit $EXIT",
		"check:type": "tsc --noEmit",
		"fix:lint": "biome check --write .",
		"watch:lint": "onchange '**/*.ts' --initial -- bun run check:lint",
		"watch:test": "onchange '**/*.ts' --initial -- bun run check:test",
		"watch:type": "onchange '**/*.ts' --initial -- bun run check:type"
	},
	"dependencies": {
		"@trpc/client": "11.10.0",
		"@hono/trpc-server": "^0.3.2",
		"@trpc/server": "11.10.0",
		"hono": "^4.12.14",
		"embedded-postgres": "^18.3.0-beta.16",
		"pg": "^8.20.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.9.3"
	}
}
