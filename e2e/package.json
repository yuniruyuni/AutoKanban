		"@trpc/client": "11.18.0",
		"@trpc/server": "11.18.0",
		"embedded-postgres": "^18.3.0-beta.16",
		"hono": "^4.12.14",
		"pg": "^8.20.0",
		"zod": "^4"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^6.0.0"
	}
}
