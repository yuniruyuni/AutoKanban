{
	"name": "@auto-kanban/e2e",
	"private": true,
	"type": "module",
	"scripts": {
		"check:lint": "biome check .",
		"check:test": "./scripts/run-test.sh",
		"check:type": "tsc --noEmit",
		"fix:lint": "biome check --write .",
		"watch:lint": "onchange '**/*.ts' --initial -- bun run check:lint",
